<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="peg_drone">
    <static>false</static>
    <!-- Includiamo l'x500 originale. merge=true fonde i modelli nello stesso namespace dei link -->
    <include merge="true">
      <uri>model://x500</uri>
    </include>

    <!-- Aggiungiamo il link del PEG -->
    <link name="peg_link">
      <gravity>true</gravity>
      <inertial>
        <mass>0.1</mass>
        <!-- Inerzia corretta per cilindro solido: m=0.1, r=0.02, l=1.0
             Ixx = Iyy = m/12*(3r^2 + l^2) ≈ 0.00834
             Izz = m/2*r^2 = 0.00002 -->
        <inertia>
          <ixx>0.00834</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.00834</iyy><iyz>0</iyz>
          <izz>0.00002</izz>
        </inertia>
      </inertial>
      <collision name="peg_collision">
        <geometry>
          <cylinder>
            <radius>0.02</radius>
            <length>1.0</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="peg_visual">
        <geometry>
          <cylinder>
            <radius>0.02</radius>
            <length>1.0</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.8 0.2 1</ambient>
          <diffuse>0.2 0.2 0.8 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
      <!-- Posizionato davanti al drone (orizzontale) -->
      <pose>0.5 0 -0.05 0 1.5708 0</pose>
    </link>

    <!-- Giunto universale: simula peg "non ben poggiato" con oscillazione su 2 assi -->
    <joint name="peg_joint" type="universal">
      <parent>base_link</parent>
      <child>peg_link</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-0.2618</lower>  <!-- -15 deg -->
          <upper>0.2618</upper>   <!-- +15 deg -->
        </limit>
        <dynamics>
          <damping>0.1</damping>
          <spring_stiffness>2.0</spring_stiffness>
        </dynamics>
      </axis>
      <axis2>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.2618</lower>  <!-- -15 deg -->
          <upper>0.2618</upper>   <!-- +15 deg -->
        </limit>
        <dynamics>
          <damping>0.1</damping>
          <spring_stiffness>2.0</spring_stiffness>
        </dynamics>
      </axis2>
    </joint>

    <!-- I motori sono gestiti dai plugin MulticopterMotorModel dell'x500 (merge=true) -->
    <!-- Il plugin SetPegPosePlugin e i JointController visivi sono stati rimossi -->

  </model>

</sdf>
